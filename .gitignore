# ============================================================
# Patent-GPT .gitignore
# ============================================================

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl

# ── Virtual Environments ───────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Environment Variables / Secrets ────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
*.crt
credentials*.json
serviceAccount*.json
secrets.*

# ── IDE / Editor ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── AI Coding Tools (local configs, NOT for repo) ─────────
CLAUDE.md
.claude/
.cursor/
.copilot/
.windsurf/
.aider*
.codex/
.codeium/
.continue/
.supermaven/

# ── OS ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
._*

# ── Logs ───────────────────────────────────────────────────
*.log
logs/
firebase-debug.log

# ── Testing / Coverage ─────────────────────────────────────
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.tox/
.nox/

# ── Linting / Formatting ──────────────────────────────────
.ruff_cache/

# ── Data / ML Artifacts (large binary files) ───────────────
data/chromadb/
*.docx
*.bin
*.pt
*.onnx
*.h5
*.hdf5
*.parquet
*.arrow
*.safetensors
*.model

# ── Database ───────────────────────────────────────────────
*.db
*.sqlite3

# ── Node (if any frontend later) ──────────────────────────
node_modules/

# ── Firebase ───────────────────────────────────────────────
.firebaserc

# ── Local Planning Materials ───────────────────────────────
docs (have to gitignore this!)/

# ── Git Worktrees ──────────────────────────────────────────
.worktrees/
