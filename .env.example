# LLM
OPENAI_API_KEY=sk-...

# KIPRISplus
KIPRIS_API_KEY=...

# Model settings
LLM_MODEL=gpt-4o
LLM_MODEL_MINI=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Search settings
SIMILARITY_THRESHOLD=0.8
MAX_EVASION_ATTEMPTS=3
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5

# ChromaDB
CHROMA_PERSIST_DIR=./data/chromadb
